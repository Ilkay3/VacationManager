@model IEnumerable<Project>

<h2>Projects</h2>

<a asp-action="Create" class="btn btn-primary">New Project</a>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var p in Model)
        {
                <tr>
                    <td>@p.Name</td>
                    <td>@p.Description</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@p.Id">Edit</a> |
                        <a asp-action="Delete" asp-route-id="@p.Id">Delete</a>
                    </td>
                </tr>
        }
    </tbody>
</table>