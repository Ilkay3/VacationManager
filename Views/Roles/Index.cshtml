
@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>

<h2>Roles</h2>

<a asp-action="Create" class="btn btn-primary">New Role</a>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var role in Model)
        {
                <tr>
                    <td>@role.Name</td>
                    <td>
                        <a asp-action="Delete" asp-route-id="@role.Id" class="btn btn-danger btn-sm">
                            Delete
                        </a>
                    </td>
                </tr>
        }
    </tbody>
</table>

