@model IEnumerable<Team>

@{
    ViewData["Title"] = "Teams";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Teams</h1>
    @if (User.IsInRole("CEO"))
    {
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Create Team</a>
    }
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <form method="get" class="mb-4">
            <div class="row g-2">
                <div class="col-md-4">
                    <input type="text" name="search" class="form-control" placeholder="Team name..." value="@ViewBag.Search" />
                </div>
                <div class="col-md-4">
                    <input type="text" name="project" class="form-control" placeholder="Project name..." value="@ViewBag.ProjectFilter" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i> Filter</button>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Project</th>
                        <th>Team Lead</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                            <tr>
                                <td>@item.Name</td>
                                <td>@item.Project?.Name</td>
                                <td>@item.TeamLead?.FullName</td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i> Details</a>
                                @if (User.IsInRole("CEO"))
                                {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Delete</a>
                                }
                                </td>
                            </tr>
                    }
                </tbody>
            </table>
        </div>

        @await Html.PartialAsync("_Pagination")
    </div>
</div>