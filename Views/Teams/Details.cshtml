@model Team

@{
    ViewData["Title"] = "Team Details";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h2 class="h4 mb-3">@Model.Name</h2>
                <hr />
                <dl class="row">
                    <dt class="col-sm-3">Project</dt>
                    <dd class="col-sm-9">@Model.Project?.Name</dd>
                    <dt class="col-sm-3">Team Lead</dt>
                    <dd class="col-sm-9">@Model.TeamLead?.FullName</dd>
                </dl>
                <div class="d-flex justify-content-between">
                    @if (User.IsInRole("CEO"))
                    {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit</a>
                    }
                    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-transparent border-0 pt-3">
                <h5 class="mb-0">Team Members</h5>
            </div>
            <div class="card-body">
                @if (ViewBag.Members != null && ((List<ApplicationUser>)ViewBag.Members).Any())
                {
                        <ul class="list-group list-group-flush">
                        @foreach (var user in (List<ApplicationUser>)ViewBag.Members)
                        {
                                    <li class="list-group-item">@user.FirstName @user.LastName (@user.Email)</li>
                        }
                        </ul>
                }
                else
                {
                        <p class="text-muted">No members in this team.</p>
                }
            </div>
        </div>
    </div>
</div>