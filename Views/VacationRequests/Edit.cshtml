@model VacationRequest

@{
    ViewData["Title"] = "Edit Vacation Request";
}

<h2>Edit Vacation Request</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <!-- Start Date -->
    <div class="mb-3">
        <label asp-for="StartDate"></label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <!-- End Date -->
    <div class="mb-3">
        <label asp-for="EndDate"></label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <!-- Vacation Type -->
    <div class="mb-3">
        <label>Vacation Type</label>
                <select asp-for="VacationTypeId" class="form-control"
                    asp-items="ViewBag.VacationTypeId">
                </select>
    </div>

    <!-- Half Day -->
    <div class="mb-3">
        <label>
            <input asp-for="IsHalfDay" type="checkbox" />
            Half Day
        </label>
    </div>

    <!-- Existing File -->
    @if (Model.FilePath != null)
    {
            <div class="mb-3">
                <label>Current File:</label>
                <a href="@Model.FilePath" target="_blank">Download</a>
            </div>
    }

    <!-- New File -->
    <div class="mb-3">
        <label>Replace File</label>
        <input type="file" name="file" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="MyRequests" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}