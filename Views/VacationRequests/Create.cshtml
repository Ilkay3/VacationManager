@model VacationManager.Models.VacationRequest

@{
    ViewData["Title"] = "Create Vacation Request";
}

<h2>Create Vacation Request</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="All" class="text-danger"></div>
    <!-- Start Date -->
    <div class="mb-3">
        <label asp-for="StartDate"></label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <!-- End Date -->
    <div class="mb-3">
        <label asp-for="EndDate"></label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <!-- Vacation Type -->
    <div class="mb-3">
        <label asp-for="VacationTypeId"></label>
        <select asp-for="VacationTypeId"
                class="form-control"
                asp-items="ViewBag.VacationTypeId">
        </select>
        <span asp-validation-for="VacationTypeId" class="text-danger"></span>
    </div>

    <!-- Half Day -->
    <div class="mb-3">
        <label>
            <input asp-for="IsHalfDay" type="checkbox" />
            Half Day
        </label>
    </div>

    <!-- File -->
    <div class="mb-3">
        <label>Medical Document (for Sick leave)</label>
        <input type="file" name="file" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Submit</button>
    <a asp-action="MyRequests" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}