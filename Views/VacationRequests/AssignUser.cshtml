
@{
    ViewData["Title"] = "AssignUser";
}

<h2>Assign User to Team</h2>

<form asp-action="AssignUser" method="post">
    <div class="mb-3">
        <label>User</label>
        <select name="userId" asp-items="ViewBag.Users" class="form-control"></select>
    </div>

    <div class="mb-3">
        <label>Team</label>
        <select name="teamId" asp-items="ViewBag.Teams" class="form-control"></select>
    </div>

    <button type="submit" class="btn btn-primary">Assign</button>
</form>

