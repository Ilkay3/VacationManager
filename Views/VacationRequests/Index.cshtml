@model IEnumerable<VacationManager.Models.VacationRequest>

@{
    ViewData["Title"] = "Vacation Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Vacation Requests</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Create New</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Created On</th>
                        <th>Half Day</th>
                        <th>Status</th>
                        <th>Type</th>
                        <th>File</th>
                        <th>User</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                            <tr>
                                <td>@item.StartDate.ToShortDateString()</td>
                                <td>@item.EndDate.ToShortDateString()</td>
                                <td>@item.CreatedOn.ToLocalTime().ToString("g")</td>
                                <td>@(item.IsHalfDay ? "Yes" : "No")</td>
                                <td>
                                @if (item.Status == "Approved")
                                {
                                            <span class="badge bg-success">Approved</span>
                                }
                                else if (item.Status == "Rejected")
                                {
                                            <span class="badge bg-danger">Rejected</span>
                                }
                                else if (item.Status == "Pending CEO")
                                {
                                            <span class="badge bg-info text-dark">Pending CEO</span>
                                }
                                else
                                {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                }
                                </td>
                                <td>@item.VacationType?.Name</td>
                                <td>
                                @if (!string.IsNullOrEmpty(item.FilePath))
                                {
                                            <a href="@item.FilePath" target="_blank" class="btn btn-sm btn-outline-info">
                                                <i class="bi bi-download"></i>
                                            </a>
                                }
                                </td>
                                <td>@item.User?.Email</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-eye"></i> Details
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>