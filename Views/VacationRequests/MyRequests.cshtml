@model IEnumerable<VacationRequest>

@{
    ViewData["Title"] = "My Vacation Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">My Vacation Requests</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Request</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Start</th>
                        <th>End</th>
                        <th>Type</th>
                        <th>Half Day</th>
                        <th>Status</th>
                        <th>File</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model)
                    {
                            <tr>
                                <td>@v.StartDate.ToShortDateString()</td>
                                <td>@v.EndDate.ToShortDateString()</td>
                                <td>@v.VacationType?.Name</td>
                                <td>@(v.IsHalfDay ? "Yes" : "No")</td>
                                <td>
                                @if (v.Status == "Pending")
                                {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                }
                                else if (v.Status == "Approved")
                                {
                                            <span class="badge bg-success">Approved</span>
                                }
                                else if (v.Status == "Rejected")
                                {
                                            <span class="badge bg-danger">Rejected</span>
                                }
                                else if (v.Status == "Pending CEO")
                                {
                                            <span class="badge bg-info text-dark">Pending CEO</span>
                                }
                                </td>
                                <td>
                                @if (v.FilePath != null)
                                {
                                            <a href="@v.FilePath" target="_blank" class="btn btn-sm btn-outline-info"><i class="bi bi-download"></i> Download</a>
                                }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@v.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
                                    <a asp-action="Delete" asp-route-id="@v.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Delete</a>
                                </td>
                            </tr>
                    }
                </tbody>
            </table>
        </div>

        @await Html.PartialAsync("_Pagination")
    </div>
</div>