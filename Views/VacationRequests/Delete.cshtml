@model VacationRequest

@{
    ViewData["Title"] = "Delete Vacation Request";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h2 class="h4 mb-3 text-danger">Delete Vacation Request</h2>
                <p class="text-muted">Are you sure you want to delete this request?</p>
                <hr />
                <dl class="row">
                    <dt class="col-sm-3">Start Date</dt>
                    <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>
                    <dt class="col-sm-3">End Date</dt>
                    <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>
                    <dt class="col-sm-3">Type</dt>
                    <dd class="col-sm-9">@Model.VacationType?.Name</dd>
                    <dt class="col-sm-3">Half Day</dt>
                    <dd class="col-sm-9">@(Model.IsHalfDay ? "Yes" : "No")</dd>
                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">@Model.Status</dd>
                </dl>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-between">
                        <a asp-action="MyRequests" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>